# ── Required ──────────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-...

# ── GHES (required for open PR) ───────────────────────────────────────────────

GHES_URL=https://github.com
GHES_BOT_TOKEN=ghp_...
TARGET_REPO=your-org/your-app-repo
SKILLS_REPO=your-org/workflow-generator

# ── Skills & DB paths ─────────────────────────────────────────────────────────
# Windows examples:
SKILLS_PATH=F:\wf-factory\skills
DB_PATH=F:\wf-factory\data\jobs.db

# ── Auth — Keycloak OIDC ──────────────────────────────────────────────────────
# AUTH_ENABLED=false  → skip auth (local dev, no Keycloak needed)
# AUTH_ENABLED=true   → require SSO login via Keycloak

AUTH_ENABLED=false
KEYCLOAK_ISSUER=https://your-keycloak-host/realms/your-realm
KEYCLOAK_CLIENT_ID=workflow-generator
KEYCLOAK_CLIENT_SECRET=

# ── Frontend NextAuth (put in apps/frontend/.env.local too) ───────────────────
NEXTAUTH_SECRET=change-me-run-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ── Tuning ────────────────────────────────────────────────────────────────────
MAX_FIX_RETRIES=3
PORT=4000
NODE_ENV=production
